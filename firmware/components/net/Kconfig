menu "Network (WiFi + telemetry)"

config WIFI_SSID
    string "WiFi SSID"
    default "Wokwi-GUEST"
    help
        SSID della rete WiFi. In Wokwi usare "Wokwi-GUEST" (rete aperta).

config WIFI_PASSWORD
    string "WiFi password"
    default ""
    help
        Password WiFi. Vuota per reti aperte (es. Wokwi-GUEST).

config DESK_ID
    string "Desk ID"
    default "desk-01"
    help
        Identificativo del nodo, usato come tag desk_id nella telemetria.

config PROXY_TELEMETRY_URL
    string "URL endpoint telemetria del proxy"
    default "http://CHANGE-ME.ngrok-free.dev/telemetry"
    help
        URL completo del POST telemetria. In Wokwi (public gateway, gratis) si
        raggiungono solo host PUBBLICI: esporre il proxy locale con un tunnel
        (ngrok http 8080) e mettere qui quell'URL http. Aggiornarlo ogni volta
        che il tunnel cambia. Su hardware reale in LAN: http://<ip>:8080/telemetry.

choice COMM_MODE_DEFAULT
    prompt "Trasporto telemetria di default"
    default COMM_MODE_DEFAULT_COAP
    help
        Trasporto usato all'avvio. Commutabile a runtime con
        net_set_communication_mode() (fase 05: aggiornabile da remoto via MQTT).

config COMM_MODE_DEFAULT_HTTP
    bool "HTTP"
config COMM_MODE_DEFAULT_COAP
    bool "CoAP"
endchoice

config COAP_SERVER_URI
    string "CoAP server URI"
    default "coap://93.49.108.145:5683/telemetry"
    help
        URI del server CoAP del proxy (aiocoap). Es. coap://<host>:5683/telemetry.
        NB: in Wokwi il Public Gateway raggiunge solo host pubblici e i tunnel free
        (ngrok/cloudflared) NON inoltrano UDP -> CoAP funziona su hardware reale in
        LAN (coap://<ip>:5683/telemetry) o con un gateway/tunnel UDP a pagamento.

config MQTT_BROKER_URI
    string "MQTT broker URI"
    default "mqtt://10.69.69.50:1883"
    help
        Broker mosquitto della fase 00 (TCP plain). Formato mqtt://host:1883.
        Il nodo pubblica gli eventi su desk/<id>/event e si sottoscrive a
        desk/<id>/config. In Wokwi serve un host pubblico o un tunnel TCP
        (es. ngrok tcp 1883): il public gateway non raggiunge la LAN. Su
        hardware reale in LAN: mqtt://<ip>:1883.

endmenu
